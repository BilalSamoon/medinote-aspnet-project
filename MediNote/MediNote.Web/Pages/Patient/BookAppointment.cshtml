@page
@model MediNote.Web.Pages.Patient.BookAppointmentModel

<h2>Book New Appointment</h2>

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

<form method="post">
    <div class="form-group row mb-3">
        <label asp-for="DoctorName" class="col-sm-2 col-form-label">Doctor</label>
        <div class="col-sm-5">
            <select asp-for="DoctorName" class="form-control">
                <option value="Dr. Smith">Dr. Smith</option>
                <option value="Dr. Adams">Dr. Adams</option>
                <option value="Dr. Lee">Dr. Lee</option>
            </select>
        </div>
    </div>

    <div class="form-group row mb-3">
        <label asp-for="RequestedDate" class="col-sm-2 col-form-label">Date</label>
        <div class="col-sm-5">
            <input asp-for="RequestedDate" type="date" class="form-control" />
        </div>
    </div>
    
    <div class="form-group row mb-3">
        <label asp-for="RequestedTime" class="col-sm-2 col-form-label">Time</label>
        <div class="col-sm-5">
            <input asp-for="RequestedTime" type="time" class="form-control" />
        </div>
    </div>
    
    <div class="form-group row mb-3">
        <label asp-for="Symptoms" class="col-sm-2 col-form-label">Symptoms</label>
        <div class="col-sm-5">
            <textarea asp-for="Symptoms" class="form-control" rows="4"></textarea>
        </div>
    </div>

    <div class="form-group row">
        <div class="col-sm-5 offset-sm-2">
            <button type="submit" class="btn btn-primary">Book Appointment</button>
            <a asp-page="/Patient/Dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>