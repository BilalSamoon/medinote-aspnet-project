@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row g-4">

    <div class="col-md-4">
        <div class="card shadow-sm border-primary">
            <div class="card-body">
                <h5 class="card-title">Reports</h5>
                <a asp-action="Reports" class="btn btn-primary">View</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-dark">
            <div class="card-body">
                <h5 class="card-title">Priority</h5>
                <a asp-action="PriorityReport" class="btn btn-dark">View</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-success">
            <div class="card-body">
                <h5 class="card-title">Appointments</h5>
                <a asp-action="ManageAppointments" class="btn btn-success">Manage</a>
            </div>
        </div>
    </div>

</div>