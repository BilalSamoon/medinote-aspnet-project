@model MediNote.Web.ViewModels.PendingAppointmentsViewModel

@{
    ViewData["Title"] = "Manage Appointments";
}

<h1 class="mb-4">Manage Appointments</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success shadow-sm">
        @Model.StatusMessage
    </div>
}

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Patient</th>
            <th>Date</th>
            <th>Symptoms</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PendingAppointments)
        {
            <tr>
                <td>@item.AppointmentId</td>
                <td>@item.PatientName</td>
                <td>@item.RequestedDate.ToShortDateString()</td>
                <td>@item.Symptoms</td>
                <td>
                    <div class="d-flex gap-2">

                        <form asp-action="ApproveAppointment" method="post">
                            <input type="hidden" name="id" value="@item.AppointmentId" />
                            <button class="btn btn-success btn-sm">Approve</button>
                        </form>

                        <form asp-action="RejectAppointment" method="post">
                            <input type="hidden" name="id" value="@item.AppointmentId" />
                            <button class="btn btn-danger btn-sm">Reject</button>
                        </form>

                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>