@model MediNote.Web.ViewModels.PendingAppointmentsViewModel

@{
    ViewData["Title"] = "Manage Appointments";
}

<h1 class="mb-4">Manage Appointments</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success shadow-sm">
        @Model.StatusMessage
    </div>
}

<table class="table table-striped table-hover shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Patient</th>
            <th>Date</th>
            <th>Symptoms</th>
            <th>Priority</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.PendingAppointments.Any())
        {
            <tr>
                <td colspan="6" class="text-center text-muted">
                    No pending appointments.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model.PendingAppointments)
            {
                var symptoms = item.Symptoms.ToLower();
                string priority = "LOW";

                if (symptoms.Contains("chest") || symptoms.Contains("heart") || symptoms.Contains("breathing"))
                {
                    priority = "HIGH";
                }
                else if (symptoms.Contains("fever") || symptoms.Contains("infection") || symptoms.Contains("pain"))
                {
                    priority = "MEDIUM";
                }

                <tr>
                    <td>@item.AppointmentId</td>
                    <td>@item.PatientName</td>
                    <td>@item.RequestedDate.ToShortDateString()</td>
                    <td>@item.Symptoms</td>

                    <td>
                        @if (priority == "HIGH")
                        {
                            <span class="badge bg-danger">HIGH</span>
                        }
                        else if (priority == "MEDIUM")
                        {
                            <span class="badge bg-warning text-dark">MEDIUM</span>
                        }
                        else
                        {
                            <span class="badge bg-success">LOW</span>
                        }
                    </td>

                    <td>
                        <div class="d-flex gap-2">

                            <form asp-action="ApproveAppointment" method="post">
                                <input type="hidden" name="id" value="@item.AppointmentId" />
                                <button class="btn btn-success btn-sm">Approve</button>
                            </form>

                            <form asp-action="RejectAppointment" method="post">
                                <input type="hidden" name="id" value="@item.AppointmentId" />
                                <button class="btn btn-danger btn-sm">Reject</button>
                            </form>

                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>