@{
    ViewData["Title"] = "System Reports";
}

<h1 class="mb-4">System Reports</h1>

<div class="row g-4">

    <div class="col-md-6">
        <div class="card shadow-sm border-primary text-center">
            <div class="card-body">
                <h5 class="card-title">Total Appointments</h5>
                <h2 class="text-primary">@ViewBag.TotalAppointments</h2>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-warning text-center">
            <div class="card-body">
                <h5 class="card-title">Pending Appointments</h5>
                <h2 class="text-warning">@ViewBag.PendingAppointments</h2>
            </div>
        </div>
    </div>

</div>

<div class="mt-4">
    <a asp-action="Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>