@page
@model MediNote.Web.Pages.Account.LoginModel

<h2>Login</h2>

<p>Please enter your credentials to log in.</p>

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

<form method="post">
    <div class="form-group row mb-3">
        <label asp-for="Username" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-5">
            <input asp-for="Username" class="form-control" />
        </div>
    </div>

    <div class="form-group row mb-3">
        <label asp-for="Password" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-5">
            <input asp-for="Password" type="password" class="form-control" />
        </div>
    </div>

    <div class="form-group row mb-3">
        <label class="col-sm-2 col-form-label">Doctor/Admin ID</label>
        <div class="col-sm-5">
            <input asp-for="SecurityId" class="form-control" placeholder="Leave blank if Patient" />
        </div>
    </div>

    <div class="form-group row">
        <div class="col-sm-5 offset-sm-2">
            <button type="submit" class="btn btn-primary">Log In</button>
            <a asp-page="/Account/Register" class="btn btn-secondary">Register</a>
        </div>
    </div>
</form>
