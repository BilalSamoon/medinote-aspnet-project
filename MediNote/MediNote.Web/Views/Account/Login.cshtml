@page
@model MediNote.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell">
    <div class="auth-card shadow-lg">
        <div class="auth-header">
            <div>
                <span class="eyebrow">Secure Sign-In</span>
                <h1>Welcome back</h1>
                <p class="text-muted mb-0">Patients log in with username and password. Doctors and admins also enter their Doctor/Admin ID.</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="alert alert-success soft-alert mt-3">
                <div>@Model.SuccessMessage</div>
                @if (!string.IsNullOrWhiteSpace(Model.IssuedSecurityId))
                {
                    <div class="mt-2"><strong>Your account ID:</strong> <code>@Model.IssuedSecurityId</code></div>
                }
            </div>
        }

        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger soft-alert mt-3">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post" class="mt-4">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control form-control-lg" />
                </div>
                <div class="col-12">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control form-control-lg" />
                </div>
                <div class="col-12">
                    <label class="form-label">Doctor / Admin ID</label>
                    <input asp-for="SecurityId" class="form-control form-control-lg" placeholder="Required for doctor and admin sign-in" />
                </div>
            </div>

            <div class="d-flex gap-3 mt-4 flex-wrap">
                <button type="submit" class="btn btn-primary btn-lg px-4">Log In</button>
                <a asp-page="/Account/Register" class="btn btn-outline-secondary btn-lg px-4">Create Account</a>
            </div>
        </form>
    </div>
</div>
