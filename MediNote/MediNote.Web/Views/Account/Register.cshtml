@page
@model MediNote.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-shell">
    <div class="auth-card shadow-lg">
        <div class="auth-header">
            <div>
                <span class="eyebrow">MediNote Access</span>
                <h1>Create your account</h1>
                <p class="text-muted mb-0">Patients get a personal portal. Doctors and admins can self-register and receive their own secure ID for login.</p>
            </div>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger soft-alert mt-3">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post" class="mt-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Username" class="form-label"></label>
                    <input asp-for="Username" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="name@email.com" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select form-select-lg" id="roleSelect">
                        <option value="Patient">Patient</option>
                        <option value="Doctor">Doctor</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>

            <div class="info-strip mt-3" id="doctorInfo" style="display:none;">
                <strong>Doctor registration:</strong> MediNote will automatically issue your Doctor ID after signup. Save it and use it during login.
            </div>

            <div class="info-strip mt-3" id="adminInfo" style="display:none;">
                <strong>Admin registration:</strong> Each administrator receives a unique Admin ID after signup. Use that Admin ID with your username and password to sign in.
            </div>

            <div class="d-flex gap-3 mt-4 flex-wrap">
                <button type="submit" class="btn btn-primary btn-lg px-4">Create Account</button>
                <a asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg px-4">Go to Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleSelect = document.getElementById("roleSelect");
            const doctorInfo = document.getElementById("doctorInfo");
            const adminInfo = document.getElementById("adminInfo");

            function toggleRoleUI() {
                const role = roleSelect.value;
                doctorInfo.style.display = role === "Doctor" ? "block" : "none";
                adminInfo.style.display = role === "Admin" ? "block" : "none";
            }

            roleSelect.addEventListener("change", toggleRoleUI);
            toggleRoleUI();
        });
    </script>
}
