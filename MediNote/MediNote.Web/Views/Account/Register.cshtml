@page
@model MediNote.Web.Pages.Account.RegisterModel

<h2>Register</h2>

<p>Create a new account.</p>

@if (!ModelState.IsValid)
{
    <div class="alert alert-danger">
        <div asp-validation-summary="All"></div>
    </div>
}

<form method="post">
    <div class="form-group row mb-3">
        <label asp-for="Username" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-5">
            <input asp-for="Username" class="form-control" />
        </div>
    </div>
    
    <div class="form-group row mb-3">
        <label asp-for="Password" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-5">
            <input asp-for="Password" type="password" class="form-control" />
        </div>
    </div>
    
    <div class="form-group row mb-3">
        <label asp-for="Role" class="col-sm-2 col-form-label"></label>
        <div class="col-sm-5">
            <select asp-for="Role" class="form-control" id="roleSelect">
                <option value="Patient">Patient</option>
                <option value="Doctor">Doctor</option>
                <option value="Admin">Admin</option>
            </select>
        </div>
    </div>

    <div class="form-group row mb-3" id="securityIdGroup" style="display:none;">
        <label class="col-sm-2 col-form-label">Doctor/Admin ID</label>
        <div class="col-sm-5">
            <input asp-for="SecurityId" class="form-control" placeholder="Required for Doctor or Admin" />
        </div>
    </div>

    <div class="form-group row">
        <div class="col-sm-5 offset-sm-2">
            <button type="submit" class="btn btn-primary">Register</button>
            <a asp-page="/Account/Login" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var roleSelect = document.getElementById("roleSelect");
            var securityGroup = document.getElementById("securityIdGroup");

            function toggleSecurityId() {
                if (roleSelect.value === "Doctor" || roleSelect.value === "Admin") {
                    securityGroup.style.display = "flex";
                } else {
                    securityGroup.style.display = "none";
                }
            }

            roleSelect.addEventListener("change", toggleSecurityId);
            toggleSecurityId(); // init on load
        });
    </script>
}