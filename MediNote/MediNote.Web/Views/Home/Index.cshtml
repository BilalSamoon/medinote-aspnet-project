@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">

    <h1 class="display-4">Welcome to MediNote</h1>

    <p class="lead">
        A healthcare appointment management system designed to streamline scheduling,
        improve efficiency, and prioritize patient needs.
    </p>

    <hr class="my-4" />

    @if (!User.Identity.IsAuthenticated)
    {
        <p>Please login or register to continue.</p>

        <a class="btn btn-primary me-2" asp-page="/Account/Login">Login</a>
        <a class="btn btn-outline-secondary" asp-page="/Account/Register">Register</a>
    }
    else
    {
        <p class="mb-3">Welcome back, @User.Identity.Name!</p>

        @if (User.IsInRole("Patient"))
        {
            <a class="btn btn-primary" asp-page="/Patient/Dashboard">Go to Dashboard</a>
        }
        else if (User.IsInRole("Doctor"))
        {
            <a class="btn btn-primary" asp-controller="Doctor" asp-action="Schedule">View Schedule</a>
        }
        else if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a>
        }
    }

</div>