@model MediNote.Web.ViewModels.ManageAvailabilityViewModel
@{
    ViewData["Title"] = "Manage Availability";
}

<div class="portal-header mb-4">
    <div>
        <span class="eyebrow">Doctor Workspace</span>
        <h1>Manage availability</h1>
        <p class="text-muted mb-0">Publish appointment windows so patients and admins can book against your schedule.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success soft-alert">@Model.StatusMessage</div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="app-card h-100">
            <h3 class="mb-3">Add availability slot</h3>
            <form asp-action="ManageAvailability" method="post" class="row g-3">
                <div class="col-12">
                    <label asp-for="AvailableDate" class="form-label">Available Date</label>
                    <input asp-for="AvailableDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="StartTime" class="form-label">Start Time</label>
                    <input asp-for="StartTime" class="form-control" type="time" />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndTime" class="form-label">End Time</label>
                    <input asp-for="EndTime" class="form-control" type="time" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary btn-lg">Save Availability</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="app-card h-100">
            <h3 class="mb-3">Published slots</h3>
            <div class="table-responsive">
                <table class="table appointment-table align-middle">
                    <thead>
                        <tr>
                            <th>Doctor</th>
                            <th>Date</th>
                            <th>Start</th>
                            <th>End</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ExistingSlots.Any())
                        {
                            foreach (var slot in Model.ExistingSlots)
                            {
                                <tr>
                                    <td>@slot.DoctorName</td>
                                    <td>@slot.AvailableDate.ToString("yyyy-MM-dd")</td>
                                    <td>@slot.StartTime.ToString(@"hh\:mm")</td>
                                    <td>@slot.EndTime.ToString(@"hh\:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No availability slots have been created yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
