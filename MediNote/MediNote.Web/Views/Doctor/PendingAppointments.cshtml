@model MediNote.Web.ViewModels.PendingAppointmentsViewModel
@{
    ViewData["Title"] = "Pending Appointments";
    var flash = TempData["DoctorStatusMessage"]?.ToString();
}

<div class="portal-header mb-4">
    <div>
        <span class="eyebrow">Doctor Review Queue</span>
        <h1>Pending appointment requests</h1>
        <p class="text-muted mb-0">Approve, cancel, or reschedule requests before they enter the active schedule.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(flash))
{
    <div class="alert alert-info soft-alert">@flash</div>
}

<div class="app-card">
    <div class="table-responsive">
        <table class="table appointment-table align-middle">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Symptoms</th>
                    <th>Priority</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PendingAppointments.Any())
                {
                    foreach (var appointment in Model.PendingAppointments)
                    {
                        <tr>
                            <td>@appointment.PatientName</td>
                            <td>@appointment.RequestedDate.ToString("yyyy-MM-dd")</td>
                            <td>@appointment.RequestedTime</td>
                            <td>@appointment.Symptoms</td>
                            <td>
                                @if (appointment.Priority == "HIGH")
                                {
                                    <span class="badge text-bg-danger">HIGH</span>
                                }
                                else if (appointment.Priority == "MEDIUM")
                                {
                                    <span class="badge text-bg-warning">MEDIUM</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-success">@appointment.Priority</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 flex-wrap">
                                    <form asp-action="ApprovePendingAppointment" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@appointment.AppointmentId" />
                                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                    <form asp-action="CancelPendingAppointment" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@appointment.AppointmentId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Cancel this appointment?');">Cancel</button>
                                    </form>
                                    <a asp-controller="Doctor" asp-action="Reschedule" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-outline-primary">Reschedule</a>
                                    <a asp-controller="Doctor" asp-action="AppointmentDetails" asp-route-id="@appointment.AppointmentId" class="btn btn-sm btn-outline-secondary">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No pending appointments found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
