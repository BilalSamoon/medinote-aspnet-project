@model MediNote.Web.ViewModels.RescheduleAppointmentViewModel
@{
    ViewData["Title"] = "Reschedule Appointment";
}

<div class="portal-header mb-4">
    <div>
        <span class="eyebrow">Doctor Workspace</span>
        <h1>Reschedule appointment</h1>
        <p class="text-muted mb-0">Choose a new visit time for the selected patient.</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-success soft-alert">@Model.StatusMessage</div>
}

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="app-card">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="stack-card h-100">
                <h3>Current appointment</h3>
                <p><strong>ID:</strong> #@Model.AppointmentId</p>
                <p><strong>Patient:</strong> @Model.PatientName</p>
                <p><strong>Date:</strong> @Model.CurrentDate.ToString("yyyy-MM-dd")</p>
                <p class="mb-0"><strong>Time:</strong> @Model.CurrentTime</p>
            </div>
        </div>
        <div class="col-lg-7">
            <form asp-action="Reschedule" method="post" class="row g-3">
                <input asp-for="AppointmentId" type="hidden" />
                <input asp-for="PatientName" type="hidden" />
                <input asp-for="CurrentDate" type="hidden" />
                <input asp-for="CurrentTime" type="hidden" />

                <div class="col-md-6">
                    <label asp-for="NewDate" class="form-label">New Date</label>
                    <input asp-for="NewDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="NewTime" class="form-label">New Time</label>
                    <input asp-for="NewTime" class="form-control" type="time" />
                </div>
                <div class="col-12 d-flex gap-3">
                    <button type="submit" class="btn btn-primary btn-lg">Confirm Reschedule</button>
                    <a asp-controller="Doctor" asp-action="PendingAppointments" class="btn btn-outline-secondary btn-lg">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
