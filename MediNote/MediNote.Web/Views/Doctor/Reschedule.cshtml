@model MediNote.Web.ViewModels.RescheduleAppointmentViewModel

@{
    ViewData["Title"] = "Reschedule Appointment";
}

<div class="container mt-4">
    <h1 class="mb-3">Reschedule Appointment</h1>
    <p class="text-muted">
        This page allows the doctor to select a new appointment time.
    </p>

    @if (Model != null && !string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">
            @Model.StatusMessage
        </div>
    }

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            Appointment Details
        </div>
        <div class="card-body">
            <p><strong>Appointment ID:</strong> @Model.AppointmentId</p>
            <p><strong>Patient:</strong> @Model.PatientName</p>
            <p><strong>Current Date:</strong> @Model.CurrentDate.ToString("yyyy-MM-dd")</p>
            <p><strong>Current Time:</strong> @Model.CurrentTime</p>

            <form asp-action="Reschedule" method="post">
                <input asp-for="AppointmentId" type="hidden" />
                <input asp-for="PatientName" type="hidden" />
                <input asp-for="CurrentDate" type="hidden" />
                <input asp-for="CurrentTime" type="hidden" />

                <div class="mb-3">
                    <label asp-for="NewDate" class="form-label">New Date</label>
                    <input asp-for="NewDate" class="form-control" type="date" />
                    <span asp-validation-for="NewDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewTime" class="form-label">New Time</label>
                    <input asp-for="NewTime" class="form-control" type="time" />
                    <span asp-validation-for="NewTime" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Confirm Reschedule</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}