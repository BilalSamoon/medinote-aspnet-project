@model MediNote.Web.ViewModels.DoctorScheduleViewModel

@{
    ViewData["Title"] = "Doctor Schedule";
}

<div class="container mt-4">
    <h1 class="mb-3">Doctor Schedule</h1>
    <p class="text-muted">
        This page allows the doctor to view scheduled appointments.
    </p>
    <p class="text-muted">
        <strong>Doctor:</strong> @Model.DoctorName
    </p>
    <p class="text-muted">
        <strong>Schedule Date:</strong> @Model.ScheduleDate.ToString("yyyy-MM-dd")
    </p>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            Today's Appointments
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in Model.Appointments)
                    {
                        <tr>
                            <td>@appointment.PatientName</td>
                            <td>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</td>
                            <td>@appointment.AppointmentTime</td>
                            <td>@appointment.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>